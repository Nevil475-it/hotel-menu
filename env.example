# ============================================================
# KADAL TAREY — Environment Variables
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to git.
# ============================================================

# ── SERVER ──────────────────────────────────────────────────
PORT=3000
# Origin of your frontend (for CORS). Use * for development.
FRONTEND_ORIGIN=*

# ── RAZORPAY ────────────────────────────────────────────────
# Get these from https://dashboard.razorpay.com → Settings → API Keys
# Use test keys (rzp_test_...) for testing, live keys (rzp_live_...) for production.
RAZORPAY_KEY_ID=rzp_test_XXXXXXXXXXXXXXXX
RAZORPAY_KEY_SECRET=XXXXXXXXXXXXXXXXXXXXXXXX

# ── MYSQL DATABASE ───────────────────────────────────────────
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_NAME=kadal_tarey
